    "DROP_COLS = [\"id\", \"datetime\", \"name\", \"lat\", \"lng\"]\n",
    "\n",
    "# Target column\n",
    "TARGET = \"bikes\"  # or 'target' if you've already created the shifted target\n",
    "\n",
    "def prepare_features(df, drop_cols=DROP_COLS, target=TARGET):\n",
    "    \"\"\"split the dataframe into features and predictions\"\"\"\n",
    "    X = df.drop(columns=drop_cols + [target])\n",
    "    y = df[target]\n",
    "    return X, y\n",
