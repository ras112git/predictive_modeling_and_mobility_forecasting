+def recency_weights(datetimes, halflife_days=30.0):
+    """Exponential-decay sample weights that favour the most recent rows.
+
+    The Kaggle test window is a contiguous *future* block, and bike usage
+    drifts up into spring, so rows near the end of the training period are more
+    representative of the test period than the autumn/winter rows. Weighting
+    recent rows up nudges the model's overall level toward the test period and
+    directly counters the under-prediction that RMSLE punishes.
+
+    Weight of a row = 0.5 ** (age_in_days / halflife_days), where age is measured
+    from the most recent timestamp. `halflife_days=30` means a row one month
+    older than the newest counts half as much; pass a larger half-life for a
+    gentler tilt, or None to disable (returns all-ones).
+
+    Args:
+        datetimes: array-like / Series of row timestamps (parseable by pandas).
+        halflife_days: half-life of the decay in days. None -> uniform weights.
+
+    Returns:
+        1-D numpy array of non-negative weights, aligned with `datetimes`.
+    """
+    import numpy as np
+    import pandas as pd
+
+    ts = pd.to_datetime(pd.Series(datetimes).values)
+    if halflife_days is None:
+        return np.ones(len(ts), dtype="float64")
+    age_days = (ts.max() - ts) / np.timedelta64(1, "D")
+    return np.power(0.5, age_days / float(halflife_days)).astype("float64")
+
+
