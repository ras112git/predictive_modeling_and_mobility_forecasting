+def time_holdout_validation(
+    df_raw,
+    model_name,
+    best_params=None,
+    holdout_weeks=7,
+    log_target=True,
+    drop_cols=("id", "datetime", "name"),
+    target="bikes",
+    recency_halflife_days=None,
+    random_state=42,
+    cache_dir=None,
+    verbose=True,
+):
+    """Leakage-free forecast validation on a chronological holdout.
+
+    This is the honest local metric the project was missing. The benchmark /
+    nested-CV numbers are optimistic because the target-derived features
+    (`avg_bikes_per_station`, `tprof_*`) are computed on the *whole* training
+    frame before the folds are cut, so each validation row's feature already
+    "knows" its own target. That inflates CV and makes it disagree with the
+    Kaggle leaderboard.
+
+    Here the raw training data is split by time into an earlier `fit` part and
+    the last `holdout_weeks` as a pseudo-test block — the same shape as the
+    real train→test gap. `clean_data` is run with `is_train=True` on the fit
+    part (which *rebuilds the target caches from the fit part only*, into a
+    scratch directory) and with `is_train=False` on the holdout, so the holdout
+    features are mapped from the fit part exactly like the real test. The model
+    is then fit on the fit part and scored on the holdout with RMSLE.
+
+    Use it to compare feature/hyperparameter/weighting changes: a change that
+    lowers this RMSLE should move the leaderboard the same way.
+
+    Args:
+        df_raw: the RAW training dataframe (as read from the CSV, before any
+            cleaning), with `datetime`, `station_number` and `target` columns.
+        model_name: key from `get_model_grid()`.
+        best_params: params to set on the estimator; None fits library defaults.
+        holdout_weeks: size of the chronological holdout, in weeks.
+        recency_halflife_days: if set, fit with `recency_weights` of this
+            half-life (measured on the fit part). None = uniform weights.
+        cache_dir: scratch directory for the fit-part target caches. None uses
+            a fresh temporary directory that is cleaned up afterwards.
+
+    Returns:
+        Dict with keys {rmse, mae, rmsle, n_fit, n_holdout, cutoff} where
+        `cutoff` is the timestamp separating fit and holdout.
+    """
+    import shutil
+    import tempfile
+    from pathlib import Path
+
+    import numpy as np
+    import pandas as pd
+    from sklearn.metrics import (
+        mean_absolute_error, mean_squared_error, mean_squared_log_error,
+    )
+
+    try:
+        from src.data_cleaning import clean_data
+    except ImportError:  # when src/ is on the path directly
+        from data_cleaning import clean_data
+
+    df = df_raw.copy()
+    df["datetime"] = pd.to_datetime(df["datetime"], utc=True).dt.tz_localize(None)
+    df = df.sort_values("datetime")
+
+    cutoff = df["datetime"].max() - pd.Timedelta(weeks=holdout_weeks)
+    fit_raw = df[df["datetime"] <= cutoff]
+    hold_raw = df[df["datetime"] > cutoff]
+    if len(fit_raw) == 0 or len(hold_raw) == 0:
+        raise ValueError(
+            f"holdout_weeks={holdout_weeks} leaves an empty split "
+            f"(fit={len(fit_raw)}, holdout={len(hold_raw)})."
+        )
+
+    owns_dir = cache_dir is None
+    cache_dir = tempfile.mkdtemp(prefix="holdout_cache_") if owns_dir else cache_dir
+    try:
+        fit_clean = clean_data(fit_raw, is_train=True, cache_dir=cache_dir)
+        hold_clean = clean_data(hold_raw, is_train=False, cache_dir=cache_dir)
+
+        # The holdout keeps its rows (is_train=False), but it comes from the
+        # train file, so drop any residual NA target rows before scoring.
+        hold_clean = hold_clean[hold_clean[target].notna()]
+
+        X_fit, y_fit = data_split(fit_clean, target)
+        X_hold, y_hold = data_split(hold_clean, target)
+        fit_datetimes = X_fit["datetime"]
+
+        X_fit = prepare_features(X_fit, list(drop_cols))
+        X_hold = prepare_features(X_hold, list(drop_cols))
+
+        sw = (
+            recency_weights(fit_datetimes, recency_halflife_days)
+            if recency_halflife_days is not None else None
+        )
+
+        model = train_final_model(
+            X_fit, y_fit, model_name,
+            best_params=best_params or {},
+            log_target=log_target,
+            sample_weight=sw,
+            random_state=random_state,
+            verbose=verbose,
+        )
+
+        y_pred = np.maximum(0, model.predict(X_hold))
+        result = {
+            "rmse": float(np.sqrt(mean_squared_error(y_hold, y_pred))),
+            "mae": float(mean_absolute_error(y_hold, y_pred)),
+            "rmsle": float(np.sqrt(mean_squared_log_error(y_hold, y_pred))),
+            "n_fit": int(len(X_fit)),
+            "n_holdout": int(len(X_hold)),
+            "cutoff": cutoff,
+        }
+    finally:
+        if owns_dir:
+            shutil.rmtree(cache_dir, ignore_errors=True)
+
+    if verbose:
+        print(
+            f"[time_holdout_validation] cutoff={cutoff}  "
+            f"fit={result['n_fit']:,}  holdout={result['n_holdout']:,}  "
+            f"RMSLE={result['rmsle']:.4f}  RMSE={result['rmse']:.3f}  "
+            f"MAE={result['mae']:.3f}"
+        )
+    return result
+
 def evaluate(model, X, y):
     """Return a dict {rmse, mae, rmsle} for predictions on (X, y)."""
 
